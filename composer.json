{
  "name": "catpaw/starter-svelte",
  "type": "project",
  "description": "A php CatPaw starter template using svelte",
  "homepage": "https://github.com/tncrazvan/catpaw-starter-svelte",
  "license": "MIT",
  "keywords": [
    "php",
    "cli",
    "server",
    "http",
    "websocket",
    "starter",
    "template",
    "catpaw"
  ],
  "scripts": {
    "load": "@composer dump-autoload -o",
    "fix": [
      "@php ./vendor/bin/php-cs-fixer fix src/php",
      "@php ./vendor/bin/php-cs-fixer fix tests/php"
    ]
  },
  "authors": [
    {
      "name": "Razvan Tanase",
      "email": "tangent.jotey@gmail.com",
      "homepage": "https://github.com/tncrazvan",
      "role": "Developer"
    }
  ],
  "autoload": {
    "psr-4": {
      "app\\": [
        "src/php/lib/"
      ]
    }
  },
  "require": {
    "php": "^8.0",
    "catpaw/core": "^1.2",
    "amphp/amp": "^2.6",
    "amphp/file": "^2.0",
    "catpaw/web": "^1.1"
  },
  "autoload-dev": {
    "Tests\\": "tests/"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "friendsofphp/php-cs-fixer": "^3.8"
  },
  "config": {
    "preferred-install": "dist",
    "process-timeout": 0
  }
}
